#!/usr/bin/env bash

# browser-open opens a link in either a work or personal browser depending on configuration.
#
# The desktop setting com.willnorris.desktop.browser-profile has four values:
#
#   personal - open with the personal browser
#   work - open with the work browser
#   default - choose the browser based on time of day and day of week
#   reverse - open the opposite of whatever would normally be used
#
# When set to default, the work profile is used during weekday working hours
# (Monday to Friday, 08:00 to 17:00).
# Otherwise, the personal browser is used.

work="/usr/bin/firefox-developer-edition"
personal="/usr/bin/firefox"
time="$(date +%H:%M)"

profile=$(gsettings get com.willnorris.desktop browser-profile | cut -d "'" -f2)

case $profile in
"default" | "reverse")
  if [[ $(date +%u) -le 5 ]] && [[ "$time" > "08:00" ]] && [[ "$time" < "17:00" ]]; then
    [ "$profile" = "reverse" ] && active="personal" || active="work"
  else
    [ "$profile" = "reverse" ] && active="work" || active="personal"
  fi
  ;;
*) active=$profile ;;
esac

case $active in
"personal") $personal "$@" ;;
"work") $work "$@" ;;
esac
